# Telegram Bot Configuration
DDOS_BOT_TOKEN=your_bot_token_here
DDOS_ADMIN_CHAT_ID=your_chat_id_here

# Traffic Analysis
DDOS_BLOCK_THRESHOLD=1000
DDOS_AUTO_UNBLOCK_MINUTES=60
DDOS_MONITOR_INTERFACE=eth0
DDOS_MONITOR_PORT=80
DDOS_RATE_WINDOW_SECONDS=10

# Security
DDOS_FACE_SIMILARITY_THRESHOLD=0.6
DDOS_SESSION_TIMEOUT_MINUTES=30

# Performance
DDOS_WORKER_COUNT=4
DDOS_MAX_QUEUE_SIZE=10000

# Logging
DDOS_LOG_LEVEL=INFO
DDOS_LOG_FORMAT=json

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme

# Database
DATABASE_URL=sqlite:///data/ddos.db

# Monitoring
DDOS_METRICS_PORT=9090
DDOS_HEALTH_PORT=8080

# Grafana (optional)
GRAFANA_PASSWORD=admin